# ChronoVisor 配置
#
# LLM 统一配置中心 — 每个功能可独立配置 API
# 不配置的项使用默认值（mimo-v2.5）

# ═══ LLM 配置（推荐方式）═══
llm:
  # 因果挖掘：分析事件对因果关系、传导机制、历史案例
  # 需要强推理能力，推荐 mimo-v2.5 / deepseek-r1 / gpt-4o
  mining:
    api_url: https://api.xiaomimimo.com/v1
    api_key: YOUR_API_KEY
    api_model: mimo-v2.5
    temperature: 0.1
    max_tokens: 4096

  # 语义分类：事件 PEST/SWOT 分类、领域识别
  # 轻量任务，可用小模型或本地 Ollama
  semantic:
    mode: auto              # heuristic / ollama / api / auto
    api_url: https://api.xiaomimimo.com/v1
    api_key: YOUR_API_KEY
    api_model: mimo-v2.5
    ollama_url: http://localhost:11434
    ollama_model: qwen3:1.7b

  # 报告生成：综合分析报告
  # 需要好的文字组织能力
  report:
    api_url: https://api.xiaomimimo.com/v1
    api_key: YOUR_API_KEY
    api_model: mimo-v2.5
    temperature: 0.3
    max_tokens: 8192

  # 因果解释：深度解读因果传导逻辑
  # 需要最强推理能力
  explanation:
    api_url: https://api.xiaomimimo.com/v1
    api_key: YOUR_API_KEY
    api_model: mimo-v2.5
    temperature: 0.2
    max_tokens: 4096

# ═══ 旧格式兼容（semantic 段仍然生效）═══
semantic:
  mode: api
  ollama:
    model: qwen3:1.7b
    url: http://localhost:11434
  api:
    url: https://api.xiaomimimo.com/v1
    key: YOUR_API_KEY
    model: mimo-v2.5

# ═══ 其他配置 ═══
causal_chain:
  min_confidence: 0.3
  max_chains: 50

report:
  auto_detect_topic: true
